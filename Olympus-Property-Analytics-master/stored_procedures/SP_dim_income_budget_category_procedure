CREATE PROCEDURE [dbo].[SP_dim_income_budget_category_procedure]
AS
BEGIN
	SET NOCOUNT ON
	CREATE TABLE #TempCategories (
		category_name varchar(255) NULL,
		category_id int NULL,
		temp_cat_store varchar(255) NULL,
		parent_category varchar(255) NULL
	)

	INSERT INTO #TempCategories (category_name)
	SELECT DISTINCT category_name
	FROM [Olympus_Property_Staging].[dbo].[budget_statement_stage]

	INSERT INTO #TempCategories (category_name)
	SELECT DISTINCT ist.category_name
	FROM [Olympus_Property_Staging].[dbo].[income_statement_stage] AS ist
	LEFT JOIN #TempCategories AS tc ON tc.category_name = ist.category_name
	WHERE tc.category_name IS NULL

	UPDATE #TempCategories
	SET temp_cat_store =
		CASE
			WHEN category_name like '[0-9]%' 
			THEN left(category_name, charindex('-', category_name) - 1)
		END

	UPDATE #TempCategories
	SET category_id =
		CASE
			WHEN temp_cat_store like '%.%' 
			THEN left(temp_cat_store, charindex('.', temp_cat_store) - 1)
			ELSE temp_cat_store
		END

	UPDATE #TempCategories
	SET parent_category = 
		CASE
			when category_id is Null and category_name = 'Rental Income' then '0'
			when category_id is Null and category_name = 'Total Rental Income' then 'Rental Income'
			when category_id is Null and category_name = 'Operating Revenue' then '0'
			when category_id is Null and category_name = 'Total Operating Revenue' then 'Operating Revenue'
			when category_id is Null and category_name = 'Gross Income' then '0'
			when category_id is Null and category_name = 'Adjustment' then 'Operating Revenue'
			when category_id is Null and category_name = 'Total Adjustment' then 'Adjustment'
			when category_id is Null and category_name = 'Other Income' then 'Operating Revenue'
			when category_id is Null and category_name = 'Total Other Income' then 'Other Income'
			when category_id is Null and category_name = 'Retail and Commercial Income' then 'Operating Revenue'
			when category_id is Null and category_name = 'Total Retail and Commercial Income' then 'Retail and Commercial Income'
			when category_id is Null and category_name = 'Operating Expense' then '0'
			when category_id is Null and category_name = 'Total Operating Expense' then 'Operating Expense'
			when category_id is Null and category_name = 'Acquisition & Placement Costs' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Acquisition & Placement Costs' then 'Acquisition & Placement Costs'
			when category_id is Null and category_name = 'Payroll & Benefits' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Payroll & Benefits' then 'Payroll & Benefits'
			when category_id is Null and category_name = 'General & Administrative' then 'Operating Expense'
			when category_id is Null and category_name = 'Total General & Administrative' then 'General & Administrative'
			when category_id is Null and category_name = 'Management Fee' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Management Fee' then 'Management Fee'
			when category_id is Null and category_name = 'Marketing' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Marketing' then 'Marketing'
			when category_id is Null and category_name = 'Contract Services' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Contract Services' then 'Contract Services'
			when category_id is Null and category_name = 'Repair & Maintenance' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Repair & Maintenance' then 'Repair & Maintenance'
			when category_id is Null and category_name = 'Turnover Expense' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Turnover Expense' then 'Turnover Expense'
			when category_id is Null and category_name = 'Turnover Expense' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Turnover Expense' then 'Turnover Expense'
			when category_id is Null and category_name = 'Utility Expense' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Utility Expense' then 'Utility Expense'
			when category_id is Null and category_name = 'Insurance & Taxes' then 'Operating Expense'
			when category_id is Null and category_name = 'Total Insurance & Taxes' then 'Insurance & Taxes'
			when category_id is Null and category_name = 'Net Operating Income' then '0'
			when category_id is Null and category_name = 'Interest Expense' then '0'
			when category_id is Null and category_name = 'Total Interest Expense' then 'Interest Expense'
			when category_id is Null and category_name = 'Total Operating Cash Flow' then '0'
			when category_id is Null and category_name = 'Partnership & Other Expenses' then '0'
			when category_id is Null and category_name = 'Total Partnership & Other Expenses' then 'Partnership & Other Expenses'
			when category_id is Null and category_name = 'Capital Expenditures' then '0'
			when category_id is Null and category_name = 'Total Capital Expenditures' then 'Capital Expenditures'
			when category_id is Null and category_name = 'Total Net Income' then '0'
			when category_id is Null and category_name = 'Current Assets Petty Cash Only' then '0'
			when category_id is Null and category_name = 'Total Current Assets Petty Cash Only' then 'Current Assets Petty Cash Only'
			when category_id is Null and category_name = 'Inventory' then '0'
			when category_id is Null and category_name = 'Total Inventory' then 'Inventory'
			when category_id is Null and category_name = 'BS - Current Liabilities (Per Change)' then '0'
			when category_id is Null and category_name = 'Total Current Liabilities' then 'BS - Current Liabilities (Per Change)'
			when category_id is Null and category_name = 'BS - Long-Term Liabilities (Per Change)' then '0'
			when category_id is Null and category_name = 'Long-Term Liabilities' then 'BS - Long-Term Liabilities (Per Change)'
			when category_id is Null and category_name like  '%Equity - Partner%' then '0'
			when category_id is Null and category_name = 'Equity - Total Capital' then 'Equity - Partners Capital'
			when category_id is Null and category_name = 'Total Equity - Total Capital' then 'Equity - Total Capital'
			when category_id is Null and category_name = 'Total Equity' then 'Equity - Partners Capital'
			when category_id is Null and category_name = 'Total Cash Flow' then '0'
			when category_id is Null and category_name = 'Other Assets - CF' then '0'
			when category_id is Null and category_name = 'Total Other Assets - CF' then 'Other Assets - CF'
			when category_id is not Null and category_id between 4000and 4299 then 'Operating Revenue'
			when category_id is not Null and category_id between 4300and 4399 then 'Adjustment'
			when category_id is not Null and category_id between 4500and 4699 then 'Other Income'
			when category_id is not Null and category_id =4800 then 'Other Income'
			when category_id is not Null and category_id between 4700and 4799 then 'Retail and Commercial Income'
			when category_id is not Null and category_id between 5100and 5199 then 'Acquisition & Placement Costs'
			when category_id is not Null and category_id between 5500and 5599 then 'Payroll & Benefits'
			when category_id is not Null and category_id between 5600and 5701 then 'General & Administrative'
			when category_id is not Null and category_id between 5800and 5811 then 'Management Fee'
			when category_id is not Null and category_id between 5900and 5999 then 'Marketing'
			when category_id is not Null and category_id between 6000and 6099 then 'Contract Services'
			when category_id is not Null and category_id between 6100and 6299 then 'Repair & Maintenance'
			when category_id is not Null and category_id between 6500and 6599 then 'Turnover Expense'
			when category_id is not Null and category_id between 6600and 6699 then 'Utility Expense'
			when category_id is not Null and category_id between 6700and 6799 then 'Insurance & Taxes'
			when category_id is not Null and category_id between 6800and 6899 then 'Interest Expense'
			when category_id is not Null and category_id between 2810and 2811 then 'Interest Expense'
			when category_id is not Null and category_id between 2820and 2821 then 'Interest Expense'
			when category_id is not Null and category_id between 6900and 6999 then 'Partnership & Other Expenses'
			when category_id is not Null and category_id between 8000and 8499 then 'Capital Expenditures'
			when category_id is not Null and category_id between 9000and 9200 then 'Capital Expenditures'
			when category_id is not Null and category_id between 1000and 1450 then 'Current Assets Petty Cash Only'
			when category_id is not Null and category_id between 1490and 1491 then 'Inventory'
			when category_id is not Null and category_id between 1530and 1531 then 'Other Assets - CF'
			when category_id is not Null and category_id between 2000and 2300 then 'BS - Current Liabilities (Per Change)'
			when category_id is not Null and category_id between 2700and 2799 then 'BS - Current Liabilities (Per Change)'
			when category_id is not Null and category_id between 2800and 2900 then 'BS - Long-Term Liabilities (Per Change)'
			when category_id is not Null and category_id between 3000and 3299 then 'Equity - Total Capital'
		end
		where parent_category is Null

	INSERT INTO [Olympus_Property_Analytics].[dbo].[dim_income_budget_category] (
				category_name
			   ,category_code
			   ,parent_category_name)
	SELECT tc.category_name
		  ,tc.category_id
		  ,tc.parent_category
	FROM #TempCategories tc
	LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_income_budget_category] tw
		ON tw.category_name = tc.category_name
	WHERE tw.category_name IS NULL

	DROP TABLE #TempCategories
END