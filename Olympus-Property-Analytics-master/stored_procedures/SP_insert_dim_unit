CREATE PROCEDURE [dbo].[SP_insert_dim_unit]
AS
BEGIN
	SET NOCOUNT ON
	CREATE TABLE #dim_unit_temp (
		 site_id_property_unit_number [varchar](70)
		,onsiteid [varchar](50)
		,property_name [varchar](70) 
		,property_number [varchar](50)
		,unit_number [varchar](50) 
		,floor_plan [varchar](30) 
		,number_of_bedrooms [varchar](10)
		,sqft [varchar](10)
		,floor_level [varchar](5)
	)

	INSERT INTO #dim_unit_temp (
		 onsiteid
		,property_name
		,unit_number
		,floor_plan
		,number_of_bedrooms
		,sqft
		,floor_level	
	)
	SELECT DISTINCT aus.[On Site id]
	      ,aus.[Property Name]
		  ,aus.[Bldg/Unit]
		  ,aus.[Floor plan]
		  ,tos.[# of bedrooms]
		  ,COALESCE(aus.SQFT,REPLACE(ast.[SQFT], ',', ''))
		  ,ast.[Floor Level]
	FROM [Olympus_Property_Staging].[dbo].[all_units_stage] AS aus
	LEFT JOIN [Olympus_Property_Staging].[dbo].[turnover_stage] AS tos ON tos.OnSiteId = aus.[On Site id] AND tos.[Unit #] = aus.[Bldg/Unit]
	LEFT JOIN [Olympus_Property_Staging].[dbo].[availability_stage] AS ast ON ast.[OnSiteId] = aus.[On Site id] AND ast.[Bldg/ Unit] = aus.[Bldg/Unit]

	INSERT INTO #dim_unit_temp (
		 onsiteid
		,property_name
		,unit_number
		,floor_plan
	)
	SELECT lds.[On Site id]
	      ,lds.[Property Name]
		  ,lds.[Unit #]
		  ,lds.[Floor plan]
	FROM  [Olympus_Property_Staging].[dbo].[lease_details_stage] AS lds
	LEFT JOIN #dim_unit_temp dut ON dut.onsiteid = lds.[On Site id] AND dut.unit_number = lds.[Unit #]
	WHERE lds.[Unit #] !='None' and dut.onsiteid is null and dut.unit_number is null

	UPDATE #dim_unit_temp
	SET property_name =
		CASE
			WHEN property_name = 'Cedar Park and Canyon Falls Townhomes' AND unit_number LIKE '%CF%' THEN 'Canyon Falls'
			WHEN property_name = 'Cedar Park and Canyon Falls Townhomes' AND unit_number LIKE '%CP%' THEN 'Cedar Park'
			WHEN property_name = 'Olympus Encantada' AND floor_plan LIKE '%sp%' THEN 'Olympus Encantada - San Pedro'
			WHEN property_name = 'Olympus Encantada' AND floor_plan LIKE '%sm%' THEN 'Olympus Encantada - Santa Monica'
			WHEN property_name = 'Mirador and Stovall at River City' AND unit_number LIKE '%M-%' THEN 'Mirador'
			WHEN property_name = 'Mirador and Stovall at River City' AND unit_number LIKE '%S-%' THEN 'Stovall'
			WHEN property_name = 'Olympus Alameda' AND (floor_plan = 'A1' OR
														floor_plan = 'A2' OR
														floor_plan = 'B1' OR
														floor_plan = 'A1-ADA' OR
														floor_plan = 'B1-ADA' OR
														floor_plan = 'C1' OR
														floor_plan = 'C1-ADA') THEN 'Olympus Alameda - Phase l'
			ELSE property_name
		END

	UPDATE #dim_unit_temp
	SET property_name = 'Olympus Alameda - Phase ll'
	WHERE property_name = 'Olympus Alameda'

	UPDATE t
	SET t.property_number = COALESCE(ps.property_number, ps.[entity_id])
	FROM #dim_unit_temp AS t
	LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_info_property] AS ps ON t.property_name = ps.property_name

	UPDATE t
	SET t.property_number = COALESCE(ps.property_number, ps.[entity_id])
	FROM #dim_unit_temp AS t
	LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_info_property] AS ps ON t.property_name = ps.[entity_name]
	
	UPDATE #dim_unit_temp
	SET site_id_property_unit_number = CONCAT(onsiteid, '-', property_number, '-', unit_number)

	ALTER TABLE #dim_unit_temp
	ALTER COLUMN site_id_property_unit_number [varchar](70) NOT NULL

	ALTER TABLE #dim_unit_temp
	ADD CONSTRAINT PK_dim_unit_temp PRIMARY KEY (site_id_property_unit_number)

	MERGE INTO [Olympus_Property_Analytics].[dbo].[dim_unit]  AS target
	USING (
		SELECT 	 CAST(site_id_property_unit_number AS varchar(50)) AS site_id_property_unit_number
				,CAST(onsiteid AS int) AS onsiteid
				,CAST(property_name AS varchar(70)) AS property_name
				,CAST(property_number AS int) AS property_number
				,CAST(unit_number AS varchar(30)) AS unit_number
				,CAST(floor_plan AS varchar(30)) AS floor_plan
				,CAST(number_of_bedrooms AS float) AS number_of_bedrooms
				,CAST(sqft AS int) AS sqft
				,CAST(floor_level AS varchar(5)) AS floor_level
		FROM #dim_unit_temp
	) AS source ON target.site_id_property_unit_number = source.site_id_property_unit_number
	WHEN MATCHED
	 AND (CHECKSUM(target.floor_plan, target.number_of_bedrooms, target.sqft, target.floor_level)
	         <> CHECKSUM(source.floor_plan, source.number_of_bedrooms, source.sqft, source.floor_level))
	THEN 
		UPDATE SET target.floor_plan = source.floor_plan
			      ,target.number_of_bedrooms = source.number_of_bedrooms
				  ,target.sqft = source.sqft
				  ,target.floor_level = source.floor_level
				  ,target.modified_date = GETDATE()
	WHEN NOT MATCHED BY TARGET
		THEN INSERT ( site_id_property_unit_number
					 ,onsiteid
					 ,property_name
					 ,property_number
					 ,unit_number
					 ,floor_plan
					 ,number_of_bedrooms
					 ,sqft
					 ,floor_level
					 ,modified_date
		)
		VALUES (
			source.site_id_property_unit_number
		   ,source.onsiteid
		   ,source.property_name
		   ,source.property_number
		   ,source.unit_number
		   ,source.floor_plan
		   ,source.number_of_bedrooms
		   ,source.sqft
		   ,source.floor_level
		   ,GETDATE()
		);

	DROP TABLE #dim_unit_temp
END