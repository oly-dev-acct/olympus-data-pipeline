alter  PROCEDURE [dbo].[SP_POPULATE_DIM_DATE]
    @StartYear INT,
    @EndYear INT
AS
BEGIN
SET NOCOUNT ON
    INSERT INTO [Olympus_Property_Analytics].[dbo].[DimDate] (
       [date_key]
      ,[full_Date_alternate_key]
      ,[day_number_of_week]
      ,[day_name_of_week]
      ,[day_number_of_month]
      ,[day_number_of_year]
      ,[week_number_of_year]
      ,[month_name]
      ,[month_number_of_year]
      ,[calendar_quarter]
      ,[calendar_year]
      ,[calendar_semester]
      ,[fiscal_quarter]
      ,[fiscal_year]
      ,[fiscal_semester]
    )
    SELECT
        YEAR(d) * 10000 + MONTH(d) * 100 + DAY(d) AS [date_key],
        d AS [full_Date_alternate_key],
        DATEPART(WEEKDAY, d) AS [day_number_of_week],
        DATENAME(WEEKDAY, d) AS [day_name_of_week],
        DAY(d) AS [day_number_of_month],
        DATEPART(DAYOFYEAR, d) AS [day_number_of_year],
        DATEPART(WEEK, d) AS [week_number_of_year],
        DATENAME(MONTH, d) AS [month_name],
        MONTH(d) AS [month_number_of_year],
        DATEPART(QUARTER, d) AS [calendar_quarter],
        YEAR(d) AS [calendar_year],
        CASE WHEN MONTH(d) <= 6 THEN 1 ELSE 2 END AS [calendar_semester],
        DATEPART(QUARTER, DATEADD(MONTH, -3, d)) AS [fiscal_quarter],
        YEAR(DATEADD(MONTH, -3, d)) AS [fiscal_year],
        CASE WHEN MONTH(DATEADD(MONTH, -3, d)) <= 6 THEN 1 ELSE 2 END AS [fiscal_semester]
    FROM (
        SELECT TOP (DATEDIFF(DAY, CAST(CAST(@StartYear AS VARCHAR(4)) + '0101' AS DATE), CAST(CAST(@EndYear AS VARCHAR(4)) + '1231' AS DATE)) + 1)
            DATEADD(DAY, ROW_NUMBER() OVER (ORDER BY a.object_id) - 1, CAST(CAST(@StartYear AS VARCHAR(4)) + '0101' AS DATE)) AS d
        FROM sys.all_objects AS a
        CROSS JOIN sys.all_objects AS b
    ) AS dates
    ORDER BY [date_key]

    UPDATE [Olympus_Property_Analytics].[dbo].[DimDate]
    SET [start_date_of_month] = DATEFROMPARTS([calendar_year], [month_number_of_year], 1),
        [end_date_of_month] = EOMONTH(DATEFROMPARTS([calendar_year], [month_number_of_year], 1))
END
