ALTER PROCEDURE [dbo].[SP_Remove_OldData_And_Duplicates] (@NumberOfDays INT,@Type INT,@ROWCOUNT INT OUTPUT)
AS
BEGIN
    SET NOCOUNT ON
	IF @Type=1
	BEGIN
    -- Step 1: Remove data older than the specified number of days
	   DECLARE @CutOffDatebud datetime
    SET @CutOffDatebud = DATEADD(DAY, -@NumberOfDays, GETDATE())

    DELETE FROM budget_statement_stage
    WHERE CONVERT(datetime, [Insert_date]) < @CutOffDatebud

    -- Step 2: Remove duplicates with null category_value in category_value based on composite keys
    DELETE t1
    FROM budget_statement_stage t1
    JOIN (
        SELECT [propertyName], [month_end_date], category_name
        FROM budget_statement_stage
        GROUP BY [propertyName], [month_end_date], category_name
        HAVING COUNT(*) > 1
    ) t2 ON t1.[propertyName] = t2.[propertyName]
        AND t1.[month_end_date] = t2.[month_end_date]
        AND t1.category_name = t2.category_name
    WHERE t1.category_value IS NULL
	
	
	SET @ROWCOUNT = @@ROWCOUNT;
	END 

	ELSE IF @Type=2

	BEGIN
    -- Step 1: Remove data older than the specified number of days
	   DECLARE @CutOffDateprod datetime
    SET @CutOffDateprod = DATEADD(DAY, -@NumberOfDays, GETDATE())

    DELETE FROM income_statement_stage
    WHERE CONVERT(datetime, [Insert_date]) < @CutOffDateprod

    -- Step 2: Remove duplicates with null category_value in category_value based on composite keys
    DELETE t1
    FROM income_statement_stage t1
    JOIN (
        SELECT [propertyName], [month_end_date], category_name
        FROM income_statement_stage
        GROUP BY [propertyName], [month_end_date], category_name
        HAVING COUNT(*) > 1
    ) t2 ON t1.[propertyName] = t2.[propertyName]
        AND t1.[month_end_date] = t2.[month_end_date]
        AND t1.category_name = t2.category_name
    WHERE t1.category_value IS NULL
	
	
	SET @ROWCOUNT = @@ROWCOUNT;
	END


END