CREATE PROCEDURE [dbo].[SP_insert_fact_turnover_history]
AS
BEGIN
	SET NOCOUNT ON
	CREATE TABLE #turnover_stage_temp_table (
		 site_id_property_unit_number [varchar](50) NOT NULL
		,move_out_date [varchar](20)
		,move_in_date [varchar](20)
		,turnover_days [varchar](20)
		,number_of_make_ready_days [varchar](20)
		,make_ready_date [varchar](20)
		,number_of_potential_occupied_days [varchar](20)
		,floor_plan [varchar](20)
		PRIMARY KEY (site_id_property_unit_number, move_out_date)
	)


	INSERT INTO #turnover_stage_temp_table (
	     site_id_property_unit_number
		,move_out_date
		,move_in_date
		,turnover_days
		,number_of_make_ready_days
		,make_ready_date
		,number_of_potential_occupied_days
		,floor_plan
	)
	SELECT DU.site_id_property_unit_number
		  ,tos.[Move-out date]
		  ,tos.[Move-in date]
		  ,tos.[Turnover days]
		  ,tos.[# of Make ready days]
		  ,tos.[Make ready date]
		  ,tos.[# of potential occupied days]
		  ,DU.[floor_plan]
	FROM [Olympus_Property_Staging].[dbo].[turnover_stage] AS tos
	LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_unit] DU on tos.[OnSiteId]= DU.[onsiteid] and tos.[Unit #] =DU.[unit_number]


	--Data Cleaning
	UPDATE #turnover_stage_temp_table
	SET move_in_date = NULL
	WHERE move_in_date = 'VACANT';

	--For rows that exist but have some updated data
	WITH MaxDates AS (
	SELECT site_id_property_unit_number
		  ,move_out_date
		  ,move_in_date
		  ,turnover_days
		  ,number_of_make_ready_days
		  ,make_ready_date
		  ,number_of_potential_occupied_days
	FROM (
		SELECT th.site_id_property_unit_number
			  ,th.move_out_date 
			  ,th.move_in_date 
			  ,th.turnover_days
		      ,th.number_of_make_ready_days 
			  ,th.make_ready_date 
			  ,th.number_of_potential_occupied_days
		      ,ROW_NUMBER() OVER(PARTITION BY th.site_id_property_unit_number, th.move_out_date ORDER BY th.insert_date DESC) AS row_num
		FROM [Olympus_Property_Analytics].[dbo].[fact_turnover_history] AS th
		) AS sub_que
	WHERE row_num=1
	)
	INSERT INTO [Olympus_Property_Analytics].[dbo].[fact_turnover_history] (
								site_id_property_unit_number
							   ,move_out_date 
							   ,move_in_date 
							   ,turnover_days
		                       ,number_of_make_ready_days 
							   ,make_ready_date 
							   ,number_of_potential_occupied_days
		  )
	SELECT CAST(site_id_property_unit_number AS varchar(50))
		  ,CAST(tos.move_out_date AS date)
		  ,CAST(tos.move_in_date AS date)
		  ,CAST(tos.turnover_days AS int)
		  ,CAST(tos.number_of_make_ready_days AS int)
		  ,CAST(tos.make_ready_date AS date) 
		  ,CAST(tos.number_of_potential_occupied_days AS int)
	FROM #turnover_stage_temp_table AS tos
	EXCEPT
	SELECT md.site_id_property_unit_number
		  ,md.move_out_date
		  ,md.move_in_date
		  ,md.turnover_days
		  ,md.number_of_make_ready_days
		  ,md.make_ready_date
		  ,md.number_of_potential_occupied_days
	FROM MaxDates AS md

	DROP TABLE #turnover_stage_temp_table
END