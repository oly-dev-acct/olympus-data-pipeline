CREATE OR ALTER PROCEDURE [dbo].[SP_populate_income_budget_fact_table] @Type INT
AS
BEGIN
    SET NOCOUNT ON
    IF @Type = 1
    BEGIN


        create table #temporary_table_fact_budget_statement
        (
            [propertyID] int not null
          , [month_end_date] date not null
          , [category_id] int not null
          , [category_value] money
          , [Insert_date] datetime
        )



        insert into #temporary_table_fact_budget_statement
        (
            [propertyID]
          , [month_end_date]
          , [category_id]
          , [category_value]
          , [Insert_date]
        )
        select dip.[entity_id]
             , bss.month_end_date
             , ibc.[category_id]
             , bss.category_value
             , bss.Insert_date
        from Olympus_Property_Staging.dbo.budget_statement_stage                bss
            left join Olympus_Property_Analytics.dbo.dim_info_property          dip
                on bss.propertyName = dip.entity_name
            left join Olympus_Property_Analytics.dbo.dim_income_budget_category ibc
                on bss.category_name = ibc.category_name


        delete from #temporary_table_fact_budget_statement
        where category_id = 138
              and category_value is null


        DELETE target
        FROM [Olympus_Property_Analytics].[dbo].[fact_budget_statement] AS target
            INNER JOIN #temporary_table_fact_budget_statement           AS source
                ON target.[propertyID] = source.[propertyID]
                   AND target.[month_end_date] = source.[month_end_date]
                   AND target.[category_id] = source.[category_id]


        insert into [Olympus_Property_Analytics].[dbo].[fact_budget_statement]
        (
            propertyID
          , month_end_date
          , category_id
          , category_value
          , Insert_date
        )
        select [propertyID]
             , [month_end_date]
             , [category_id]
             , [category_value]
             , [Insert_date]
        from #temporary_table_fact_budget_statement






        -- Delete rows in fact_budget_statement with older Insert_dates than those in temporary_table_fact_budget_statement

        DROP TABLE #temporary_table_fact_budget_statement


    END
    ELSE IF @Type = 2
    BEGIN -- Delete rows in test_fact_INCOME_statement with older Insert_dates than those in income_statement_stage
        create table #temporary_table_fact_income_statement
        (
            [propertyID] int not null
          , [month_end_date] date not null
          , [category_id] int not null
          , [category_value] money
          , [Insert_date] datetime
        )



        insert into #temporary_table_fact_income_statement
        (
            [propertyID]
          , [month_end_date]
          , [category_id]
          , [category_value]
          , [Insert_date]
        )
        select dip.[entity_id]
             , bss.month_end_date
             , ibc.[category_id]
             , bss.category_value
             , bss.Insert_date
        from Olympus_Property_Staging.dbo.income_statement_stage                bss
            left join Olympus_Property_Analytics.dbo.dim_info_property          dip
                on bss.propertyName = dip.entity_name
            left join Olympus_Property_Analytics.dbo.dim_income_budget_category ibc
                on bss.category_name = ibc.category_name


        delete from #temporary_table_fact_income_statement
        where category_id = 138
              and category_value is null


        DELETE target
        FROM [Olympus_Property_Analytics].[dbo].[fact_income_statement] AS target
            INNER JOIN #temporary_table_fact_income_statement           AS source
                ON target.[propertyID] = source.[propertyID]
                   AND target.[month_end_date] = source.[month_end_date]
                   AND target.[category_id] = source.[category_id]


        insert into [Olympus_Property_Analytics].[dbo].[fact_income_statement]
        (
            propertyID
          , month_end_date
          , category_id
          , category_value
          , Insert_date
        )
        select [propertyID]
             , [month_end_date]
             , [category_id]
             , [category_value]
             , [Insert_date]
        from #temporary_table_fact_income_statement






        -- Delete rows in fact_income_statement with older Insert_dates than those in temporary_table_fact_income_statement

        DROP TABLE #temporary_table_fact_income_statement


    END

END