CREATE or alter  PROCEDURE [dbo].[SP_insert_dim_resident_demographics]
AS
BEGIN

SET NOCOUNT ON
    -- Create a temporary table

			create table #tmp_resident_demographics(
				[site_id_property_unit_number] [varchar](50) NULL, 
				[Gender] [varchar](10) NULL,
				[MaritalStatus] [varchar](20) NULL,
				[Citizenship/EthnicOrigin] [varchar](70) NULL,
				[ResidentStatus] [varchar](35) NULL,
				[MilesToWork] [varchar](10) NULL,
				[Income] [varchar](20) NULL,
				[Name] [varchar](200) NULL,
				[Phone] [varchar](30) NULL,
				[Birth Date] [varchar](15) NULL,
				[Age] [varchar](10) NULL,
				[Household Status] [varchar](50) NULL,
				[Signer Status] [varchar](50) NULL,
				[Employer] [varchar](50) NULL,
				[Job Type] [varchar](50) NULL
				)










  ;WITH CTE AS (
    SELECT 
        DU.[site_id_property_unit_number], 
        RDS.[Gender],
        RDS.[MaritalStatus],
        RDS.[Citizenship/EthnicOrigin],
        RDS.[ResidentStatus],
        RDS.[MilesToWork],
        RDS.[Income],
        RDS.[Name],
        RDS.[Phone],
        RDS.[Birth Date],
        RDS.[Age],
        RDS.[Household Status],
        RDS.[Signer Status],
        RDS.[Employer],
        RDS.[Job Type],
        ROW_NUMBER() OVER (
            PARTITION BY DU.[site_id_property_unit_number], RDS.[Name]
            ORDER BY
                CASE
                    WHEN [Birth Date] IS NULL THEN 1
                    ELSE 0
                END,
                [Birth Date]
        ) AS RowNumber
    FROM 
        [Olympus_Property_Staging].[dbo].[resident_demographics_stage] RDS
		left join Olympus_Property_Analytics.dbo.dim_unit DU on RDS.[On Site id]=DU.onsiteid AND RDS.Unit = DU.unit_number
		WHERE RDS.Unit NOT LIKE '%Waitlist%' 
)



insert into #tmp_resident_demographics(
		[site_id_property_unit_number],
        [Gender],
        [MaritalStatus],
        [Citizenship/EthnicOrigin],
        [ResidentStatus],
        [MilesToWork],
        [Income],
        [Name],
        [Phone],
        [Birth Date],
        [Age],
        [Household Status],
        [Signer Status],
        [Employer],
        [Job Type])
SELECT 
    [site_id_property_unit_number],
    [Gender],
    [MaritalStatus],
    [Citizenship/EthnicOrigin],
    [ResidentStatus],
    [MilesToWork],
    [Income],
    [Name],
    [Phone],
    [Birth Date],
    [Age],
    [Household Status],
    [Signer Status],
    [Employer],
    [Job Type]
FROM 
    CTE
WHERE 
    RowNumber = 1;
  



    -- Update values in the temporary table
    UPDATE #tmp_resident_demographics
    SET 
        [Gender] = NULLIF([Gender], 'None'),
        [MaritalStatus] = NULLIF([MaritalStatus], 'None'),
        [Citizenship/EthnicOrigin] = NULLIF([Citizenship/EthnicOrigin], 'None'),
        [ResidentStatus] = NULLIF([ResidentStatus], 'None'),
        [MilesToWork] = NULLIF([MilesToWork], 'None'),
        [Income] = NULLIF([Income], 'None'),
        [Name] = NULLIF([Name], 'None'),
        [Phone] = NULLIF([Phone], 'None'),
        [Birth Date] = NULLIF([Birth Date], 'None'),
        [Age] = NULLIF([Age], 'None'),
        [Household Status] = NULLIF([Household Status], 'None'),
        [Signer Status] = NULLIF([Signer Status], 'None'),
        [Employer] = NULLIF([Employer], 'None'),
        [Job Type] = NULLIF([Job Type], 'None');

		
  

  -- Update existing rows with updated data
WITH MaxDates AS (

    Select [site_id_property_unit_number]
      ,[gender]
      ,[marital_status]
      ,[citizenship_ethnic_origin]
      ,[resident_status]
      ,[miles_to_work]
      ,[income]
      ,[name]
      ,[phone]
      ,[birth_date]
      ,[age]
      ,[household_status]
      ,[signer_status]
      ,[employer]
      ,[job_type]

from (
    SELECT a.[site_id_property_unit_number]
      ,a.[gender]
      ,a.[marital_status]
      ,a.[citizenship_ethnic_origin]
      ,a.[resident_status]
      ,a.[miles_to_work]
      ,a.[income]
      ,a.[name]
      ,a.[phone]
      ,a.[birth_date]
      ,a.[age]
      ,a.[household_status]
      ,a.[signer_status]
      ,a.[employer]
      ,a.[job_type]
, ROW_NUMBER() OVER (PARTITION BY a.[site_id_property_unit_number],a.[name] ORDER BY a.[insert_date] DESC) AS row_num
    FROM [Olympus_Property_Analytics].[dbo].[dim_resident_demographics] as a 
) as sub_que 
WHERE row_num =1
)
INSERT INTO [Olympus_Property_Analytics].[dbo].[dim_resident_demographics] (
		[site_id_property_unit_number]
      ,[gender]
      ,[marital_status]
      ,[citizenship_ethnic_origin]
      ,[resident_status]
      ,[miles_to_work]
      ,[income]
      ,[name]
      ,[phone]
      ,[birth_date]
      ,[age]
      ,[household_status]
      ,[signer_status]
      ,[employer]
      ,[job_type]
)
        select 
		cast ([site_id_property_unit_number] AS varchar(50) ),
        CAST([Gender] AS varchar(5)),
        CAST([MaritalStatus] AS varchar(20)),
        CAST([Citizenship/EthnicOrigin] AS varchar(70)),
        CAST([ResidentStatus] AS varchar(35)),
        CAST([MilesToWork] AS float),
        CAST([Income] AS money),
        CAST([Name] AS varchar(200)),
        CAST([Phone] AS varchar(30)),
        CAST([Birth Date] AS date),
        CAST([Age] AS int),
        CAST([Household Status] AS varchar(50)),
        CAST([Signer Status] AS varchar(50)),
        CAST([Employer] AS varchar(50)),
        CAST([Job Type] AS varchar(50))
        FROM #tmp_resident_demographics
        except 
        select
       md.[site_id_property_unit_number]
      ,md.[gender]
      ,md.[marital_status]
      ,md.[citizenship_ethnic_origin]
      ,md.[resident_status]
      ,md.[miles_to_work]
      ,md.[income]
      ,md.[name]
      ,md.[phone]
      ,md.[birth_date]
      ,md.[age]
      ,md.[household_status]
      ,md.[signer_status]
      ,md.[employer]
      ,md.[job_type]
    From MaxDates as md






    -- Drop the temporary table
    DROP TABLE #tmp_resident_demographics;
END;