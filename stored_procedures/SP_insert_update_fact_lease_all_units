CREATE   PROCEDURE [dbo].[SP_insert_update_fact_lease_all_units]
AS
BEGIN

--Creating temp table 
  create table #TMP_TABLE_LEASE_ALL_UNITS(
								[site_id_property_unit_number] [varchar](50) NOT NULL,
								[Market Rent] [varchar](10) NULL,
								[Amt/SQFT] [varchar](10) NULL,
								[Lease Rent] [varchar](10) NULL,
								[Actual Amt/SQFT] [varchar](10) NULL,
								[Name] [varchar](200) NULL,
								[Move-in] [varchar](10) NULL,
								[Lease Start] [varchar](10) NULL,
								[Lease End] [varchar](10) NULL,
								[Deposits On Hand] [varchar](10) NULL,
								[Made Ready] [varchar] (5) NULL,
								[Effective Rent] [varchar](10) NULL,
								
								 
  )

  INSERT INTO #TMP_TABLE_LEASE_ALL_UNITS(
		[site_id_property_unit_number]
      ,[Market Rent]
      ,[Amt/SQFT]
      ,[Lease Rent]
      ,[Actual Amt/SQFT]
      ,[Name]
      ,[Move-in]
      ,[Lease Start]
      ,[Lease End]
      ,[Deposits On Hand]
      ,[Made Ready]
      ,[Effective Rent]
		)
		SELECT   
		DU.[site_id_property_unit_number]
      ,AUS.[Market Rent]
      ,AUS.[Amt/SQFT]
      ,AUS.[Lease Rent]
      ,AUS.[Actual Amt/SQFT]
      ,AUS.[Name]
      ,AUS.[Move-in]
      ,AUS.[Lease Start]
      ,AUS.[Lease End]
      ,AUS.[Deposits On Hand]
      ,AUS.[Made Ready]
      ,AUS.[Effective Rent]
		
  FROM [Olympus_Property_Staging].[dbo].all_units_stage  AUS 
  LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_unit] DU on AUS.[On Site id]=DU.[onsiteid] and AUS.[Bldg/Unit]=DU.[unit_number]




  --Cleaning temptable
	UPDATE #TMP_TABLE_LEASE_ALL_UNITS
	SET [site_id_property_unit_number] = NULLIF([site_id_property_unit_number], 'None')
	, [Market Rent] = NULLIF([Market Rent], 'None')
	, [Amt/SQFT] = NULLIF([Amt/SQFT], 'None')
	, [Lease Rent] = NULLIF([Lease Rent], 'None')
	, [Actual Amt/SQFT] = NULLIF([Actual Amt/SQFT], 'None')
	, [Name] = NULLIF([Name], 'None')
	, [Move-in] = NULLIF([Move-in], 'None')
	, [Lease Start] = NULLIF([Lease Start], 'None')
	, [Lease End] = NULLIF([Lease End], 'None')
	, [Deposits On Hand] = NULLIF([Deposits On Hand], 'None')
	, [Made Ready] = NULLIF([Made Ready], 'None')
	, [Effective Rent] = NULLIF([Effective Rent], 'None')
   

   	UPDATE #TMP_TABLE_LEASE_ALL_UNITS
	SET [site_id_property_unit_number] = NULLIF([site_id_property_unit_number], '')
	, [Market Rent] = NULLIF([Market Rent], '')
	, [Amt/SQFT] = NULLIF([Amt/SQFT], '')
	, [Lease Rent] = NULLIF([Lease Rent], '')
	, [Actual Amt/SQFT] = NULLIF([Actual Amt/SQFT], '')
	, [Name] = NULLIF([Name], '')
	, [Move-in] = NULLIF([Move-in], '')
	, [Lease Start] = NULLIF([Lease Start], '')
	, [Lease End] = NULLIF([Lease End], '')
	, [Deposits On Hand] = NULLIF([Deposits On Hand], '')
	, [Made Ready] = NULLIF([Made Ready], '')
	, [Effective Rent] = NULLIF([Effective Rent], '')

	





	
  -- Merge data from the temporary table into the target table using checksum
  MERGE INTO [Olympus_Property_Analytics].[dbo].[fact_lease_all_units] AS target
    USING (
	select 
                 
                  
				  CAST ([site_id_property_unit_number] AS  [VARCHAR](50)) AS [site_id_property_unit_number]
                  ,CAST ([Market Rent] AS MONEY ) AS [Market Rent]
				  ,CAST ([Amt/SQFT] AS MONEY ) AS [Amt/SQFT]
				  ,CAST ([Lease Rent] AS MONEY ) AS [Lease Rent]
				  ,CAST ([Actual Amt/SQFT] AS MONEY ) AS [Actual Amt/SQFT]
				  ,CAST ([Name] AS [VARCHAR](200) ) AS [Name]
				  ,CAST ([Move-in] AS date ) AS [Move-in]
				  ,CAST ([Lease Start] AS date ) AS [Lease Start]
				  ,CAST ([Lease End] AS date  ) AS [Lease End]
				  ,CAST ([Deposits On Hand] AS MONEY ) AS [Deposits On Hand]
				  ,CAST ([Made Ready] AS [VARCHAR](10) ) AS [Made Ready]
				  ,CAST ([Effective Rent] AS MONEY ) AS [Effective Rent]
                  
                
            FROM #TMP_TABLE_LEASE_ALL_UNITS
          ) AS source ON target.[site_id_property_unit_number]=source.[site_id_property_unit_number]
          WHEN MATCHED
          -- Update row if checksum indicates changes
          AND CHECKSUM( target.[market_rent]
						,target.[amt_per_sqft]
						,target.[lease_rent]
						,target.[actual_amt_per_sqft]
						,target.[name]
						,target.[move_in]
						,target.[lease_start]
						,target.[lease_end]
						,target.[deposits_on_hand]
						,target.[made_ready]
						,target.[effective_rent]
					
    )
            <> CHECKSUM(source.[Market Rent]
						,source.[Amt/SQFT]
						,source.[Lease Rent]
						,source.[Actual Amt/SQFT]
                        ,source.[Name]
						,source.[Move-in]
						,source.[Lease Start]
                        ,source.[Lease End]
						,source.[Deposits On Hand]
						,source.[Made Ready]
						,source.[Effective Rent])

        THEN
          UPDATE SET	target.[market_rent]=source.[Market Rent]
						,target.[amt_per_sqft]=source.[Amt/SQFT]
						,target.[lease_rent]=source.[Lease Rent]
						,target.[actual_amt_per_sqft]=source.[Actual Amt/SQFT]
						,target.[name]=source.[Name]
						,target.[move_in]=source.[Move-in]
						,target.[lease_start]=source.[Lease Start]
						,target.[lease_end]=source.[Lease End]
						,target.[deposits_on_hand]=source.[Deposits On Hand]
						,target.[made_ready]=source.[Made Ready]
						,target.[effective_rent] = source.[Effective Rent]
                        ,target.[modified_date] = GETDATE()
							
							
        
        WHEN NOT MATCHED BY TARGET
        -- Insert row if it doesn't exist in the target table
                    THEN INSERT (
                                
								    [site_id_property_unit_number]
									  ,[market_rent]
									  ,[amt_per_sqft]
									  ,[lease_rent]
									  ,[actual_amt_per_sqft]
									  ,[name]
									  ,[move_in]
									  ,[lease_start]
									  ,[lease_end]
									  ,[deposits_on_hand]
									  ,[made_ready]
									  ,[effective_rent]
									  ,[insert_date]
									  ,[modified_date])

                  VALUES(
						source.[site_id_property_unit_number]
						,source.[Market Rent]
						,source.[Amt/SQFT]
						,source.[Lease Rent]
						,source.[Actual Amt/SQFT]
                        ,source.[Name]
						,source.[Move-in]
						,source.[Lease Start]
                        ,source.[Lease End]
						,source.[Deposits On Hand]
						,source.[Made Ready]
						,source.[Effective Rent]
                        ,GETDATE()
                        ,GETDATE());

	 -- Clean up the temporary table
  drop table #TMP_TABLE_LEASE_ALL_UNITS

  END
GO


