CREATE PROCEDURE [dbo].[SP_insert_fact_scheduled_transaction_history]
AS
BEGIN
	SET NOCOUNT ON
	CREATE TABLE #scheduled_transaction_stage_temp_table (
		site_id_property_unit_number [varchar](50) NOT NULL
	   ,code_amenity_name varchar(600) NOT NULL
	   ,start_date varchar(40)
	   ,end_date varchar(40)
	   ,rent_ca varchar(10)
	   ,unit_amenities varchar(10)
	   ,market_rent varchar(10)
	   ,effective_rent varchar(10)
	   ,other varchar(10)
       ,market_addl varchar(10)
	   ,default_rent_code varchar(40)
	   ,default_vacancy_code varchar(30)
	)


	INSERT INTO #scheduled_transaction_stage_temp_table (
		site_id_property_unit_number
	   ,code_amenity_name
	   ,start_date
	   ,end_date
	   ,rent_ca
	   ,unit_amenities
	   ,market_rent
	   ,effective_rent
	   ,other
       ,market_addl
	   ,default_rent_code
	   ,default_vacancy_code
	)
	SELECT DU.site_id_property_unit_number
          ,[Code/ Amenity Name]
          ,[Start Date]
          ,[End Date]
          ,[Rent (CA)]
          ,[Unit Amenities]
          ,[Market Rent]
          ,[Effective Rent]
          ,[Other]
          ,[Market +Addl.]
          ,[Default Rent Code]
          ,[Default Vacancy Code]
	FROM [Olympus_Property_Staging].[dbo].[unit_scheduled_transaction_stage] AS sts
	LEFT JOIN [Olympus_Property_Analytics].[dbo].[dim_unit] DU on sts.[OnSiteId]= DU.[onsiteid] and sts.[Bldg/Unit] =DU.[unit_number]

	--Data Cleaning
	UPDATE #scheduled_transaction_stage_temp_table
	SET rent_ca = REPLACE(rent_ca, '-', '')
	WHERE rent_ca LIKE '%-%';


	INSERT INTO [Olympus_Property_Analytics].[dbo].[fact_scheduled_transaction_history] (
							site_id_property_unit_number
						   ,code_amenity_name
						   ,start_date
						   ,end_date
						   ,rent_ca
						   ,unit_amenities
						   ,market_rent
						   ,effective_rent
						   ,other
						   ,market_addl
						   ,default_rent_code
						   ,default_vacancy_code
		  )
	SELECT CAST(site_id_property_unit_number AS varchar(50))
		  ,CAST(sts.code_amenity_name AS varchar(600))
		  ,CAST(sts.start_date AS date)
		  ,CAST(sts.end_date AS date)
		  ,CAST(sts.rent_ca AS money)
		  ,CAST(sts.unit_amenities AS int) 
		  ,CAST(sts.market_rent AS money)
		  ,CAST(sts.effective_rent AS money)
		  ,CAST(sts.other AS int)
		  ,CAST(sts.market_addl AS money)
		  ,CAST(sts.default_rent_code AS varchar(40))
		  ,CAST(sts.default_vacancy_code AS varchar(30))
	FROM #scheduled_transaction_stage_temp_table AS sts
	EXCEPT
	SELECT fsth.site_id_property_unit_number
		  ,fsth.code_amenity_name
	      ,fsth.start_date
		  ,fsth.end_date
		  ,fsth.rent_ca
		  ,fsth.unit_amenities
		  ,fsth.market_rent
		  ,fsth.effective_rent
		  ,fsth.other
		  ,fsth.market_addl
		  ,fsth.default_rent_code
		  ,fsth.default_vacancy_code
	FROM [Olympus_Property_Analytics].[dbo].[fact_scheduled_transaction_history] AS fsth

	DROP TABLE #scheduled_transaction_stage_temp_table
END