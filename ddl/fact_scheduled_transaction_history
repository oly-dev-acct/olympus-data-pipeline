CREATE TABLE fact_scheduled_transaction_history (
    scheduled_transaction_history_id int IDENTITY(1,1) NOT NULL,
    insert_date datetime NOT NULL DEFAULT GETDATE(),
    site_id_property_unit_number [varchar](50) NOT NULL,
    code_amenity_name varchar(600) NOT NULL,
    start_date date NULL,
    end_date date NULL,
    rent_ca money NULL,
    unit_amenities int NULL,
    market_rent money NULL,
    effective_rent money NULL,
    other int NULL,
    market_addl money NULL,
    default_rent_code varchar(40) NULL,
    default_vacancy_code varchar(30) NULL,
	FOREIGN KEY (site_id_property_unit_number) REFERENCES dim_unit (site_id_property_unit_number)
)