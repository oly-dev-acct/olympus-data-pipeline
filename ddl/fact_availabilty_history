CREATE TABLE fact_availability_history (
	availability_history_id int IDENTITY(1,1) NOT NULL,
    insert_date datetime NOT NULL DEFAULT GETDATE(),
	site_id_property_unit_number varchar(50) NOT NULL,
	move_out_date date NULL,
	days_vacant int NULL,
	make_ready_date date NULL,
	date_applied date NULL,
	date_approved date NULL,
	scheduled_move_in date NULL,
	market_addl money NULL,
	curr_last_lease money NULL,
	estimated_vacancy_cost money NULL,
	lease_rent money NULL,
	lease_signed varchar(5) NULL,
	[name] varchar(100) NULL,
	comment varchar(500) NULL,
	[type] varchar(60) NULL,
	break_or_skip varchar(10) NULL
	FOREIGN KEY (site_id_property_unit_number) REFERENCES dim_unit (site_id_property_unit_number)
)
