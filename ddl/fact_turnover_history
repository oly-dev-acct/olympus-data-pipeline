CREATE TABLE fact_turnover_history (
	turnover_history_id int IDENTITY(1,1) NOT NULL,
    insert_date datetime NOT NULL DEFAULT GETDATE(),
	site_id_property_unit_number [varchar](50) NOT NULL,
	move_out_date date NOT NULL,
	move_in_date date NULL,
	turnover_days int NULL,
	number_of_make_ready_days int NULL,
	make_ready_date date NULL,
	number_of_potential_occupied_days int NULL
	FOREIGN KEY (site_id_property_unit_number) REFERENCES dim_unit (site_id_property_unit_number)
)
